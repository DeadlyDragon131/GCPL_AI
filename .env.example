# ─────────────────────────────────────────────────
# Copy this file to .env and fill in your Groq key
#   cp .env.example .env
#
# Get a FREE Groq API key (no credit card needed):
#   1. Go to https://console.groq.com
#   2. Sign up / log in
#   3. Click "API Keys" → "Create API Key"
#   4. Paste the key below
# ─────────────────────────────────────────────────

GROQ_API_KEY=gsk_your_key_here

# OpenAI key is NOT required — kept for optional use only
# OPENAI_API_KEY=sk_...
